{
  "name": "kurochan",
  "version": "1.1.0",
  "description": "KuroChan — Live2D desktop mascot with transparent background using Electron + PixiJS",
  "main": "src/main/index.js",
  "scripts": {
    "build:whisper": "scripts\\build-whisper.cmd",
    "build:js": "webpack --config webpack.config.js",
    "build": "npm run build:js",
    "start": "npm run build:js && electron .",
    "dev": "electron .",
    "debug": "electron . --inspect=9229 --remote-debugging-port=9222",
    "dist": "npm run build:js -- --mode production && electron-builder --win"
  },
  "devDependencies": {
    "css-loader": "^7.1.4",
    "electron": "^28.3.0",
    "electron-builder": "^24.13.3",
    "style-loader": "^4.0.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "ffmpeg-static": "^5.3.0",
    "koffi": "^2.9.0",
    "pixi-live2d-display": "^0.4.0",
    "pixi.js": "^6.5.10",
    "ws": "^8.19.0"
  },
  "build": {
    "appId": "com.kurochan.app",
    "productName": "KuroChan",
    "copyright": "Copyright © 2026",
    "asar": true,
    "asarUnpack": [
      "resources/whisper/**"
    ],
    "extraResources": [],
    "directories": {
      "output": "release",
      "buildResources": "build-resources"
    },
    "files": [
      "src/main/**",
      "index.html",
      "dist/**",
      "assets/**",
      "third_party/live2d/**",
      "resources/**",
      "package.json",
      "!resources/whisper/README.md",
      "!third_party/whisper.cpp/**",
      "!third_party/openclaw/**",
      "!third_party/build/**",
      "!third_party/CMakeLists.txt",
      "!third_party/whisper_wrapper.cpp",
      "!scripts/**",
      "!webpack.config.js",
      "!*.ps1",
      "!*.md"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "KuroChan",
      "artifactName": "${productName}-${version}-setup.exe"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.exe"
    }
  }
}
