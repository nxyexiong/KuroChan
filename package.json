{
  "name": "kurochan",
  "version": "1.0.0",
  "description": "KuroChan — Live2D desktop mascot with transparent background using Electron + PixiJS",
  "main": "main.js",
  "scripts": {
    "build:whisper": "powershell -ExecutionPolicy Bypass -File scripts/build-whisper.ps1",
    "build:js": "webpack --config webpack.config.js",
    "build": "npm run build:js",
    "start": "npm run build:js && electron .",
    "dev": "electron .",
    "debug": "electron . --inspect=9229 --remote-debugging-port=9222"
  },
  "devDependencies": {
    "css-loader": "^7.1.4",
    "electron": "^28.3.0",
    "style-loader": "^4.0.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "koffi": "^2.9.0",
    "pixi-live2d-display": "^0.4.0",
    "pixi.js": "^6.5.10"
  }
}
